{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/nastyakon14/mle_bench_agent:latest",
    entrypoint: [
      "python",
      "/app/src/server.py",
      "--host",
      "0.0.0.0",
      "--port",
      "9009"
    ],
    env: {
      LOG_LEVEL: "INFO",
      OPENAI_API_KEY: "${config.openai_api_key}",
      OPENAI_MODEL: "${config.openai_model}",
      KAGGLE_USERNAME: "${config.kaggle_username}",
      KAGGLE_KEY: "${config.kaggle_key}"
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 9009 }
      ]
    }
  },
  config_schema: {
    type: "object",
    properties: {
      openai_api_key: { type: "string", secret: true },
      openai_model: { type: "string", default: "gpt-5.1" },
      kaggle_username: { type: "string", secret: true },
      kaggle_key: { type: "string", secret: true }
    },
    required: ["kaggle_username", "kaggle_key"],
    additionalProperties: false
  },
  slots: {
    proxy: { kind: "a2a" }
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" }
  },
  exports: {
    a2a: "a2a"
  },
  metadata: {
    assessment_config: {
      "competition_id": "spaceship-titanic"
    },
    participant_roles: ["agent"]
  }
}